FROM node:22-bookworm-slim

WORKDIR /app

ENV NODE_ENV=production
ENV RUNWAY_MCP_BRIDGE_HOST=0.0.0.0
ENV RUNWAY_MCP_REMOTE_CONFIG_DIR=/data/.mcp-auth
ENV RUNWAY_MCP_REMOTE_SILENT=1

COPY package.json package-lock.json ./
RUN npm ci --omit=dev

COPY scripts/runway-mcp-remote-http-bridge.mjs ./scripts/runway-mcp-remote-http-bridge.mjs

RUN mkdir -p /data/.mcp-auth && chown -R node:node /app /data

USER node

EXPOSE 58744

CMD ["npm", "run", "start:runway-mcp-bridge"]
