VITE_SUPABASE_URL=https://PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-publishable-or-anon-key
VITE_GENERATION_PROVIDER=gemini
# Optional. The bundled same-origin /models/silueta.onnx is used by default.
# VITE_REMBG_MODEL_BASE_URL=https://your-cors-enabled-model-host.example.com/models
# VITE_REMBG_SILUETA_MODEL_URL=https://your-cors-enabled-model-host.example.com/models/silueta.onnx
# VITE_REMBG_ISNET_GENERAL_USE_MODEL_URL=https://your-cors-enabled-model-host.example.com/models/isnet-general-use.onnx
# Optional external-host override. Zeabur's build:deploy stages the pinned model at
# same-origin /models/u2net_cloth_seg.onnx without putting the 176 MB file in Git.
# VITE_REMBG_CLOTH_SEG_MODEL_URL=https://your-cors-enabled-model-host.example.com/models/u2net_cloth_seg.onnx

SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=replace-with-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-in-runtime-secret-store
SUPABASE_PROJECT_REF=PROJECT_REF
SUPABASE_ACCESS_TOKEN=replace-in-ci-secret-store

GEMINI_API_KEY=replace-in-runtime-secret-store
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
OPENAI_API_KEY=replace-in-runtime-secret-store
# Optional: route only chat/completions to an OpenAI-compatible provider.
# OPENAI_CHAT_API_KEY=replace-in-runtime-secret-store
# OPENAI_CHAT_BASE_URL=https://api.openai.com/v1
# OPENAI_CHAT_MODEL=gpt-4o-mini
PUBLIC_URL=https://heavy-chain.example.com
PLAYWRIGHT_BASE_URL=http://127.0.0.1:4173
