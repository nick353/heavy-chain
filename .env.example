# .env.example
# This is an example environment file
# Copy this file to .env and fill in your actual values

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
VITE_GENERATION_PROVIDER=gemini
# Optional. The bundled same-origin /models/silueta.onnx is used by default.
# VITE_REMBG_MODEL_BASE_URL=https://your-cors-enabled-model-host.example.com/models
# VITE_REMBG_SILUETA_MODEL_URL=https://your-cors-enabled-model-host.example.com/models/silueta.onnx
# VITE_REMBG_ISNET_GENERAL_USE_MODEL_URL=https://your-cors-enabled-model-host.example.com/models/isnet-general-use.onnx
# Optional external-host override. Zeabur's build:deploy stages the pinned model at
# same-origin /models/u2net_cloth_seg.onnx without putting the 176 MB file in Git.
# VITE_REMBG_CLOTH_SEG_MODEL_URL=https://your-cors-enabled-model-host.example.com/models/u2net_cloth_seg.onnx
# Optional point-prompt model overrides. Defaults use the official Apache-2.0 EfficientSAM-Ti ONNX files.
# VITE_EFFICIENT_SAM_ENCODER_URL=https://your-cors-enabled-model-host.example.com/models/efficient_sam_vitt_encoder.onnx
# VITE_EFFICIENT_SAM_DECODER_URL=https://your-cors-enabled-model-host.example.com/models/efficient_sam_vitt_decoder.onnx

# Stripe Configuration (Optional - for future payment features)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key-here

# Note: Never commit the actual .env file to version control!
# The .env file should be listed in .gitignore
